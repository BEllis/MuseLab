{
  "name": "@muselab/designer",
  "private": true,
  "version": "0.1.0",
  "description": "Visual novel designer and player",
  "homepage": "https://muselab.vn",
  "author": {
    "name": "MuseLab",
    "email": "dev@muselab.vn"
  },
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web-deploy": "pnpm run build:cito-wasm && vite build --mode web-deploy",
    "build": "pnpm run build:razor-grammar && pnpm run build:cito-wasm && tsc -b && vite build",
    "build:razor-grammar": "lezer-generator src/core/cito/museLabRazor.grammar -o src/core/cito/museLabRazor.parser.ts",
    "build:cito": "bash scripts/build-cito.sh",
    "build:cito-wasm": "bash scripts/build-cito-wasm.sh",
    "test": "vitest run",
    "test:integration": "vitest run integration.test",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:fixtures": "vitest run src/test/e2e/generateFixtures.test.ts",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build --mode electron && electron-builder",
    "icons": "magick src/assets/logo.png -filter Lanczos -resize 1024x1024 build/icon.png && magick build/icon.png -define icon:auto-resize=256,128,64,48,32,16 build/icon.ico && magick src/assets/logo.png -filter Lanczos -resize 192x192 public/pwa-192.png && magick src/assets/logo.png -filter Lanczos -resize 512x512 public/pwa-512.png"
  },
  "build": {
    "appId": "dev.muselab.app",
    "productName": "MuseLab",
    "artifactName": "${productName}-${version}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../../tools/cito",
        "to": "cito",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "maintainer": "MuseLab <dev@muselab.vn>",
      "executableName": "muselab"
    },
    "deb": {
      "packageName": "muselab"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "@antv/x6": "^3.1.7",
    "@antv/x6-react-shape": "^3.0.1",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/common": "^1.5.2",
    "@lezer/lr": "^1.4.10",
    "@muselab/shared": "workspace:*",
    "ajv": "^8.17.1",
    "dompurify": "^3.2.2",
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tslib": "^2.8.1",
    "workbox-window": "^7.4.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@playwright/test": "1.55.0",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
