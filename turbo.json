{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**", "dist-deploy/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "electron:dev": {
      "cache": false,
      "persistent": true
    },
    "electron:build": {
      "outputs": ["dist/**", "dist-electron/**", "release/**"]
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "preview": {
      "cache": false,
      "persistent": true
    }
  }
}
