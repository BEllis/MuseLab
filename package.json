{
  "name": "muselab",
  "private": true,
  "version": "0.1",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:cito-wasm && tsc -b && vite build",
    "build:web-deploy": "bash scripts/build-web-deploy.sh",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "build:cito": "bash scripts/build-cito.sh",
    "build:cito-wasm": "bash scripts/build-cito-wasm.sh",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build --mode electron && electron-builder",
    "icons": "magick src/assets/logo.png -filter Lanczos -resize 1024x1024 build/icon.png && magick build/icon.png -define icon:auto-resize=256,128,64,48,32,16 build/icon.ico && magick src/assets/logo.png -filter Lanczos -resize 192x192 public/pwa-192.png && magick src/assets/logo.png -filter Lanczos -resize 512x512 public/pwa-512.png"
  },
  "build": {
    "appId": "dev.muselab.app",
    "productName": "MuseLab",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "tools/cito",
        "to": "cito",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "dependencies": {
    "@antv/x6": "^3.1.7",
    "@antv/x6-react-shape": "^3.0.1",
    "ajv": "^8.17.1",
    "dompurify": "^3.2.2",
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tslib": "^2.8.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
