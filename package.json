{
  "name": "muselab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@muselab/designer",
    "build": "turbo run build --filter=!@muselab/site",
    "test": "turbo run test",
    "preview": "turbo run preview --filter=@muselab/designer",
    "electron:dev": "turbo run electron:dev --filter=@muselab/designer",
    "electron:build": "turbo run electron:build --filter=@muselab/designer",
    "deploy": "turbo run deploy --filter=@muselab/site",
    "docker:build": "docker build -f infra/muselab-site/Dockerfile --target production -t muselab-web:local .",
    "docker:build:prebuilt": "pnpm --filter @muselab/site run build && docker build -f infra/muselab-site/Dockerfile --target prebuilt -t muselab-web:local .",
    "docker:run": "docker run --rm -p 8080:80 muselab-web:local",
    "docker:up": "pnpm --filter @muselab/site run build && docker compose up --build web",
    "build:cito": "pnpm --filter @muselab/designer run build:cito",
    "icons": "pnpm --filter @muselab/designer run icons"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
